{
    "$schema": "https://opencode.ai/config.json",
    "agent": {
        "build": {
            "steps": 250,
            "temperature": 1,
            "top_p": 0.95,
            "top_k": 40,
            "auto_execute": true
        }
    },
    "permission": {
        "external_directory": {
            "*": "allow"
        }
    },
    "model": "gdc/dsv32",
    "provider": {
        "gdc": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "gdc (local)",
            "options": {
                "baseURL": "http://10.79.130.209:30000/v1"
            },
            "models": {
                "dsv32": {
                    "_launch": true,
                    "name": "dsv32",
                    "limit": {
                        "output": 65536,
                        "context": 262144
                    }
                }
            }
        }
    }
}
